        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\n\nclass BaseEntity~T~ {\n    &lt;&lt;Abstract&gt;&gt;\n    - id: T\n    - version: Long\n    - createdAt: LocalDateTime\n    - lastModifiedAt: LocalDateTime\n}\n\nclass OwnedEntity~T~ {\n    &lt;&lt;Abstract&gt;&gt;\n    - usuario: Usuario\n}\n\nclass Turma {\n    - nome: String\n}\n\nclass Usuario {\n    - email: String\n    - nome: String\n    - senha: String\n    - role: Role\n\n    + getRoleName(): String\n    + getAuthorities(): Collection~GrantedAuthority~\n    + getPassword(): String\n    + getUsername(): String\n}\n\nclass Role {\n    - nome: RoleEnum\n}\n\nclass RoleEnum {\n    &lt;&lt;enumeration&gt;&gt;\n    ADMIN\n    PROFESSOR\n    ALUNO\n}\n\nclass UserDetails {\n    &lt;&lt;interface&gt;&gt;\n    + getAuthorities(): Collection~GrantedAuthority~\n    + getPassword(): String\n    + getUsername(): String\n}\n\nclass GrantedAuthority {\n    &lt;&lt;interface&gt;&gt;\n}\n\nclass Matricula {\n    - aluno: Usuario\n    - turma: Turma\n}\n\nclass HorarioAula {\n    - turma: Turma\n    - diaSemana: DiaSemanaEnum\n    - horario: LocalTime\n}\n\nclass DiaSemanaEnum {\n    &lt;&lt;enumeration&gt;&gt;\n    SEGUNDA\n    TERÇA\n    QUARTA\n    QUINTA\n    SEXTA\n    SABADO\n    DOMINGO\n}\n\nclass Falta {\n    - horarioAula: HorarioAula\n    - matricula: Matricula\n}\n\nclass AtividadeAvaliativa {\n    - nome: String\n    - valor: Double\n    - turma: Turma\n}\n\nclass Nota {\n    - matricula: Matricula\n    - atividadeAvaliativa: AtividadeAvaliativa\n    - valor: Double\n}\n\nBaseEntity &lt;|-- OwnedEntity\nOwnedEntity &lt;|-- Turma\n\nBaseEntity &lt;|-- Usuario\nBaseEntity &lt;|-- Role\nBaseEntity &lt;|-- Matricula\nBaseEntity &lt;|-- HorarioAula\nBaseEntity &lt;|-- Falta\nBaseEntity &lt;|-- AtividadeAvaliativa\nBaseEntity &lt;|-- Nota\n\nUserDetails &lt;|.. Usuario\n\nUsuario \&quot;0..*\&quot; --&gt; \&quot;1..1\&quot; Role : role\nTurma \&quot;0..*\&quot; --&gt; \&quot;1..1\&quot; Usuario : usuario\n\nRole --&gt; RoleEnum : nome\n\nHorarioAula --&gt; DiaSemanaEnum : diaSemana\n\nMatricula \&quot;0..*\&quot; --&gt; \&quot;1..1\&quot; Usuario : aluno\nMatricula \&quot;0..*\&quot; --&gt; \&quot;1..1\&quot; Turma : turma\n\nHorarioAula \&quot;0..*\&quot; --&gt; \&quot;1..1\&quot; Turma : turma\n\nFalta \&quot;0..*\&quot; --&gt; \&quot;1..1\&quot; HorarioAula : horarioAula\nFalta \&quot;0..*\&quot; --&gt; \&quot;1..1\&quot; Matricula : matricula\n\nNota \&quot;0..*\&quot; --&gt; \&quot;1..1\&quot; Matricula : matricula\nNota \&quot;0..*\&quot; --&gt; \&quot;1..1\&quot; AtividadeAvaliativa : atividade\n\nUserDetails ..&gt; GrantedAuthority\nUsuario ..&gt; GrantedAuthority&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="9rtRNNNjqd3fd2db35To-1">
